            "post": {
                "tags": [
                    "Symptomes"
                ],
                "summary": "Enregistrer un nouveau symptome",
                "operationId": "dca672aeac264e3647552a3646df8aea",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "severity",
                                    "date_recorded"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Maux de tete"
                                    },
                                    "severity": {
                                        "type": "string",
                                        "enum": [
                                            "mild",
                                            "moderate",
                                            "severe"
                                        ]
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Douleur persistante"
                                    },
                                    "date_recorded": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-03-26"
                                    },
                                    "notes": {
                                        "type": "string",
                                        "example": "Hydratation faible"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Symptome enregistre"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
